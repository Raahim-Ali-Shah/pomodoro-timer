<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pomodoro Timer</title>
    <style>
        body {
            color: #2d3748;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            transition: background-color 0.5s ease;
        }

        .focus-bg { background-color: #fff5f5; }
        .break-bg { background-color: #f0fff4; }

        .timer-box {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            text-align: center;
            width: 90%;
            max-width: 400px;
        }

        #status-text { font-weight: 600; letter-spacing: 1px; }

        #countdown-display {
            font-size: 5rem;
            font-weight: bold;
            margin: 10px 0;
            transition: opacity 0.3s ease;
        }

        /* Paused state visual */
        .paused { opacity: 0.2; }

        button {
            padding: 12px 24px;
            font-size: 1rem;
            margin: 5px;
            cursor: pointer;
            border: none;
            border-radius: 8px;
            color: white;
            font-weight: bold;
            min-width: 110px;
            transition: transform 0.1s;
        }

        button:active { transform: scale(0.95); }

        #main-action-btn { background-color: #e53e3e; }
        #reset-btn { background-color: #a0aec0; }

        .settings-box { 
            margin-top: 30px; 
            padding-top: 20px; 
            border-top: 1px solid #e2e8f0; 
            display: flex;
            justify-content: space-evenly;
        }

        .settings-box label {
            display: flex;
            flex-direction: column;
            font-size: 0.75rem;
            color: #718096;
        }

        .settings-box input {
            width: 50px;
            padding: 6px;
            margin-top: 4px;
            text-align: center;
            border: 1px solid #cbd5e0;
            border-radius: 4px;
        }

        .history-box { 
            margin-top: 25px; 
            text-align: left; 
            max-height: 150px; 
            overflow-y: auto;
        }

        .history-box h3 { font-size: 0.9rem; color: #4a5568; margin-bottom: 8px; }

        #history-list { 
            padding: 0; 
            list-style: none; 
            font-size: 0.85rem; 
        }

        #history-list li {
            padding: 6px 0;
            border-bottom: 1px solid #edf2f7;
            color: #2d3748;
        }
    </style>
</head>
<body class="focus-bg">

    <div class="timer-box">
        <h2 id="status-text">FOCUS TIME</h2>
        <div id="countdown-display">25:00</div>
        
        <div class="button-group">
            <button id="main-action-btn">Start</button>
            <button id="reset-btn">Reset</button>
        </div>

        <div class="settings-box">
            <label>Focus (min) <input type="number" id="focus-input" value="25"></label>
            <label>Break (min) <input type="number" id="break-input" value="5"></label>
        </div>

        <div class="history-box">
            <h3>Today's History</h3>
            <ul id="history-list"></ul>
        </div>
    </div>

    <script>
        const display = document.getElementById('countdown-display');
        const statusText = document.getElementById('status-text');
        const focusInput = document.getElementById('focus-input');
        const breakInput = document.getElementById('break-input');
        const historyList = document.getElementById('history-list');
        const actionBtn = document.getElementById('main-action-btn');

        let timerInterval = null; 
        let isFocusMode = true; 
        let totalSecondsLeft = 25 * 60; 

        // --- PERSISTENCE LOGIC ---

        function getTodayKey() {
            // Returns a string like "pomodoro-2023-10-27"
            return "pomo-" + new Date().toISOString().split('T')[0];
        }

        function loadHistory() {
            const todayKey = getTodayKey();
            const saved = localStorage.getItem(todayKey);
            
            // Clear history from other days
            for (let i = 0; i < localStorage.length; i++) {
                const key = localStorage.key(i);
                if (key.startsWith('pomo-') && key !== todayKey) {
                    localStorage.removeItem(key);
                }
            }

            if (saved) {
                const logs = JSON.parse(saved);
                logs.forEach(log => renderHistoryItem(log));
            }
        }

        function saveLog(entry) {
            const todayKey = getTodayKey();
            const saved = localStorage.getItem(todayKey);
            const logs = saved ? JSON.parse(saved) : [];
            logs.unshift(entry); // Add to start
            localStorage.setItem(todayKey, JSON.stringify(logs));
        }

        // --- TIMER LOGIC ---

        function updateScreenDisplay() {
            let minutes = Math.floor(totalSecondsLeft / 60);
            let seconds = totalSecondsLeft % 60;
            display.textContent = (minutes < 10 ? "0" : "") + minutes + ":" + (seconds < 10 ? "0" : "") + seconds;
        }

        function updateColors() {
            if (isFocusMode) {
                document.body.className = "focus-bg";
                statusText.textContent = "FOCUS TIME";
                statusText.style.color = "#e53e3e";
                if (timerInterval === null) actionBtn.style.backgroundColor = "#e53e3e";
            } else {
                document.body.className = "break-bg";
                statusText.textContent = "BREAK TIME!";
                statusText.style.color = "#38a169";
                if (timerInterval === null) actionBtn.style.backgroundColor = "#38a169";
            }

            if (timerInterval === null && actionBtn.textContent !== "Start") {
                display.classList.add('paused');
                statusText.textContent = "PAUSED";
            } else {
                display.classList.remove('paused');
            }
        }

        function toggleTimer() {
            if (timerInterval === null) {
                actionBtn.textContent = "Pause";
                actionBtn.style.backgroundColor = "#4a5568";
                timerInterval = setInterval(() => {
                    if (totalSecondsLeft > 0) {
                        totalSecondsLeft--;
                        updateScreenDisplay();
                    } else {
                        handleCycleFinished();
                    }
                }, 1000);
            } else {
                clearInterval(timerInterval);
                timerInterval = null;
                actionBtn.textContent = "Resume";
            }
            updateColors();
        }

        function resetTimer() {
            clearInterval(timerInterval);
            timerInterval = null;
            isFocusMode = true;
            totalSecondsLeft = focusInput.value * 60;
            actionBtn.textContent = "Start";
            updateColors();
            updateScreenDisplay();
        }

        function handleCycleFinished() {
            clearInterval(timerInterval);
            timerInterval = null;
            new Audio("https://actions.google.com/sounds/v1/alarms/beep_short.ogg").play().catch(() => {});

            if (isFocusMode) {
                const now = new Date();
                const timeStr = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                const logEntry = "✓ " + focusInput.value + ":00 focus — " + timeStr;
                
                renderHistoryItem(logEntry);
                saveLog(logEntry);

                isFocusMode = false;
                totalSecondsLeft = breakInput.value * 60;
            } else {
                isFocusMode = true;
                totalSecondsLeft = focusInput.value * 60;
            }
            
            updateColors();
            updateScreenDisplay();
            toggleTimer();
        }

        function renderHistoryItem(text) {
            const li = document.createElement('li');
            li.textContent = text;
            historyList.prepend(li);
        }

        actionBtn.onclick = toggleTimer;
        document.getElementById('reset-btn').onclick = resetTimer;

        focusInput.onchange = () => {
            if (timerInterval === null && isFocusMode) {
                totalSecondsLeft = focusInput.value * 60;
                updateScreenDisplay();
            }
        };
        
        // Initial setup
        loadHistory();
        updateScreenDisplay();
    </script>
</body>
</html>
