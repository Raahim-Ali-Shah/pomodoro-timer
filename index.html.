<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pomodoro Timer</title>
    <style>
        body {
            color: #2d3748;
            font-family: sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            transition: background-color 0.5s ease;
        }

        .focus-bg { background-color: #fff5f5; }
        .break-bg { background-color: #f0fff4; }

        .timer-box {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            text-align: center;
            width: 100%;
            max-width: 400px;
        }

        #countdown-display {
            font-size: 5rem;
            font-weight: bold;
            margin: 20px 0;
            transition: all 0.3s ease;
        }

        /* NEW: The "Session Done" pulse animation */
        @keyframes finish-glow {
            0% { transform: scale(1); color: #2d3748; }
            50% { transform: scale(1.2); color: #38a169; }
            100% { transform: scale(1); color: #2d3748; }
        }
        .session-complete {
            animation: finish-glow 0.7s ease-in-out 2;
        }

        .paused {
            opacity: 0.3;
        }

        button {
            padding: 12px 24px;
            font-size: 1rem;
            margin: 5px;
            cursor: pointer;
            border: none;
            border-radius: 6px;
            color: white;
            font-weight: bold;
            min-width: 110px;
        }

        #main-action-btn { background-color: #e53e3e; }
        #reset-btn { background-color: #a0aec0; }

        .settings-box { 
            margin-top: 30px; 
            padding-top: 20px; 
            border-top: 1px solid #e2e8f0; 
            display: flex;
            justify-content: space-evenly;
            align-items: center;
        }

        .settings-box label {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 5px;
            font-size: 0.85rem;
        }

        .settings-box input {
            width: 45px;
            padding: 4px;
            text-align: center;
            border: 1px solid #cbd5e0;
            border-radius: 4px;
        }

        .history-box { margin-top: 20px; text-align: left; }
    </style>
</head>
<body class="focus-bg">

    <div class="timer-box">
        <h2 id="status-text">FOCUS TIME</h2>
        <div id="countdown-display">25:00</div>
        
        <div class="button-group">
            <button id="main-action-btn">Start</button>
            <button id="reset-btn">Reset</button>
        </div>

        <div class="settings-box">
            <label>Focus (min): <input type="number" id="focus-input" value="25"></label>
            <label>Break (min): <input type="number" id="break-input" value="5"></label>
        </div>

        <div class="history-box">
            <h3>Today's History</h3>
            <ul id="history-list"></ul>
        </div>
    </div>

    <script>
        const display = document.getElementById('countdown-display');
        const statusText = document.getElementById('status-text');
        const focusInput = document.getElementById('focus-input');
        const breakInput = document.getElementById('break-input');
        const historyList = document.getElementById('history-list');
        const actionBtn = document.getElementById('main-action-btn');

        let timerInterval = null; 
        let isFocusMode = true; 
        let totalSecondsLeft = 25 * 60; 

        // Persistence Logic
        function getStorageKey() { return "pomo_" + new Date().toDateString(); }

        function loadHistory() {
            const saved = localStorage.getItem(getStorageKey());
            if (saved) {
                JSON.parse(saved).forEach(entry => renderItem(entry));
            }
        }

        function saveHistory(text) {
            const key = getStorageKey();
            const logs = JSON.parse(localStorage.getItem(key) || "[]");
            logs.push(text);
            localStorage.setItem(key, JSON.stringify(logs));
        }

        function renderItem(text) {
            const li = document.createElement('li');
            li.textContent = text;
            historyList.prepend(li);
        }

        function updateScreenDisplay() {
            let minutes = Math.floor(totalSecondsLeft / 60);
            let seconds = totalSecondsLeft % 60;
            display.textContent = (minutes < 10 ? "0" : "") + minutes + ":" + (seconds < 10 ? "0" : "") + seconds;
        }

        function updateColors() {
            if (isFocusMode) {
                document.body.className = "focus-bg";
                statusText.textContent = "FOCUS TIME";
                statusText.style.color = "#e53e3e";
                if (timerInterval === null) actionBtn.style.backgroundColor = "#e53e3e";
            } else {
                document.body.className = "break-bg";
                statusText.textContent = "BREAK TIME!";
                statusText.style.color = "#38a169";
                if (timerInterval === null) actionBtn.style.backgroundColor = "#38a169";
            }

            if (timerInterval === null && actionBtn.textContent !== "Start") {
                display.classList.add('paused');
                statusText.textContent = "PAUSED";
            } else {
                display.classList.remove('paused');
            }
        }

        function toggleTimer() {
            if (timerInterval === null) {
                actionBtn.textContent = "Pause";
                actionBtn.style.backgroundColor = "#4a5568";
                timerInterval = setInterval(() => {
                    if (totalSecondsLeft > 0) {
                        totalSecondsLeft--;
                        updateScreenDisplay();
                    } else {
                        handleCycleFinished();
                    }
                }, 1000);
            } else {
                clearInterval(timerInterval);
                timerInterval = null;
                actionBtn.textContent = "Resume";
            }
            updateColors();
        }

        function handleCycleFinished() {
            clearInterval(timerInterval);
            timerInterval = null;
            new Audio("https://actions.google.com/sounds/v1/alarms/beep_short.ogg").play().catch(() => {});

            // Satisfying Moment: Add the pulse animation class
            display.classList.add('session-complete');
            setTimeout(() => display.classList.remove('session-complete'), 1500);

            if (isFocusMode) {
                const now = new Date();
                const timeStr = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                const log = "✓ " + focusInput.value + ":00 focus — " + timeStr;
                renderItem(log);
                saveHistory(log);
                isFocusMode = false;
                totalSecondsLeft = breakInput.value * 60;
            } else {
                isFocusMode = true;
                totalSecondsLeft = focusInput.value * 60;
            }
            
            updateColors();
            updateScreenDisplay();
            
            // Wait slightly so user can enjoy the "moment" before auto-starting
            setTimeout(toggleTimer, 2000);
        }

        actionBtn.onclick = toggleTimer;
        document.getElementById('reset-btn').onclick = () => {
            clearInterval(timerInterval);
            timerInterval = null;
            isFocusMode = true;
            totalSecondsLeft = focusInput.value * 60;
            actionBtn.textContent = "Start";
            updateColors();
            updateScreenDisplay();
        };

        loadHistory();
        updateScreenDisplay();
    </script>
</body>
</html>
